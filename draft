<script>
// ════════════════════════════════════════════════
//  ВСТАВЬТЕ СЮДА URL ВАШЕГО APPS SCRIPT
//  Получить: Apps Script → Развернуть → URL веб-приложения
// ════════════════════════════════════════════════
var API_URL = 'https://script.google.com/macros/s/AKfycbzMG4ZbKIEW-jX_ZWN4toZwj9U_DQ9pCanyHWUR3WNcZtq5ndA4D5PGympf-uZYvMr-/exec';

// ── Ресторан из URL (?restaurant=Галано) ─────────
var urlParams  = new URLSearchParams(window.location.search);
var presetRest = urlParams.get('restaurant') || '';

// ── Состояние ────────────────────────────────────
var ALL = [], cur = null, scanStream = null, scanRAF = null, apiScanTimer = null;

// ── Вспомогательные ──────────────────────────────
function api(params) {
  var url = API_URL + '?' + new URLSearchParams(params).toString();
  return fetch(url, { redirect: 'follow' }).then(function(r){ return r.json(); });
}
function f(n){ return parseFloat(n).toFixed(2); }
function esc(s){ return s.replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }
function ini(n){ var p=n.trim().split(' '); return (p[0][0]+(p[1]?p[1][0]:'')).toUpperCase(); }

var CAT_CSS   = {Блогер:'blogger',Спортсмен:'sport',Партнёр:'partner'};
var CAT_LABEL = {Блогер:'Блогеры',Спортсмен:'Спортсмены',Партнёр:'Сотрудники партнёров'};

function showScreen(id) {
  ['scr-main','scr-scan','scr-detail','scr-ok'].forEach(function(s){
    var el = document.getElementById(s);
    if (s === id) { el.style.display='flex'; el.classList.add('active'); }
    else          { el.style.display='none'; el.classList.remove('active'); }
  });
}

// ── Загрузка ─────────────────────────────────────
api({ action: 'getData' }).then(function(data) {
  ALL = data.people;
  var mo=['Январь','Февраль','Март','Апрель','Май','Июнь',
          'Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
  if (presetRest) {
    var el=document.getElementById('ab-rest');
    el.textContent=presetRest; el.style.display='inline-block';
  }
  document.getElementById('sec-hdr').textContent=
    mo[data.month-1]+' '+data.year+'  ·  '+ALL.length+' человек';
  draw(ALL);
}).catch(function(e) {
  document.getElementById('sec-hdr').textContent='Ошибка загрузки';
  document.getElementById('list').innerHTML='<div class="empty" style="color:var(--R)">Проверьте API_URL и соединение</div>';
});

// ── Рендер ───────────────────────────────────────
function draw(arr) {
  var wrap = document.getElementById('list');
  if (!arr.length) { wrap.innerHTML='<div class="empty">Никого не найдено</div>'; return; }
  var groups = {};
  arr.forEach(function(p){ (groups[p.category]=groups[p.category]||[]).push(p); });
  var order = ['Блогер','Спортсмен','Партнёр'];
  Object.keys(groups).forEach(function(c){ if(order.indexOf(c)===-1) order.push(c); });
  var html = '';
  order.forEach(function(cat) {
    if (!groups[cat]) return;
    var cs = CAT_CSS[cat]||'blogger';
    html += '<div class="cat-hdr"><span class="cat-pill cat-'+cs+'">'+(CAT_LABEL[cat]||cat)+'</span>'
          + '<span class="cat-count">'+groups[cat].length+'</span></div>';
    html += groups[cat].map(rowHTML).join('');
  });
  wrap.innerHTML = html;
}
function rowHTML(p) {
  var cs = CAT_CSS[p.category]||'blogger';
  var badge, bclass;
  if (p.prefType==='лимит') {
    var st=p.remain<=0?'bad':p.remain<50?'warn':'ok';
    badge=p.remain<=0?'Исчерпан':f(p.remain)+' р.'; bclass='pb-'+st;
  } else {
    badge=p.value+'%'; bclass=cs==='sport'?'pb-b':'pb-o';
  }
  var avCls=p.prefType==='лимит'&&p.remain<=0?'av-bad':'av-'+cs;
  var sub=p.prefType==='лимит'?'Потрачено '+f(p.spent)+' из '+p.value+' р.':'Скидка '+p.value+'% · '+p.id;
  return '<div class="prow" onclick="openDetail(\''+esc(p.id)+'\')">'
    +'<div class="pava '+avCls+'">'+ini(p.name)+'</div>'
    +'<div class="pinfo"><div class="pname">'+p.name+'</div><div class="psub">'+sub+'</div></div>'
    +'<div class="pbadge '+bclass+'">'+badge+'</div></div>';
}

// ── Поиск ────────────────────────────────────────
var qEl=document.getElementById('q'), qclr=document.getElementById('qclr');
qEl.addEventListener('input', function(){
  var q=this.value.toLowerCase().trim();
  qclr.classList.toggle('on',!!this.value);
  var res=q?ALL.filter(function(p){ return p.name.toLowerCase().indexOf(q)!==-1||p.id.toLowerCase().indexOf(q)!==-1; }):ALL;
  document.getElementById('sec-hdr').textContent=res.length+' из '+ALL.length+' человек';
  draw(res);
});
function clearQ(){ qEl.value=''; qclr.classList.remove('on'); draw(ALL);
  document.getElementById('sec-hdr').textContent=ALL.length+' человек'; }

// ══ СКАНЕР — BarcodeDetector + api.qrserver.com fallback ═══════

// Определяем метод сканирования один раз при загрузке
var USE_NATIVE = (typeof BarcodeDetector !== 'undefined');
var detector   = null;
if (USE_NATIVE) {
  try { detector = new BarcodeDetector({ formats: ['qr_code'] }); } catch(e) { USE_NATIVE = false; }
}

function startScan() {
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    alert('Ваш браузер не поддерживает камеру. Введите ID вручную.');
    return;
  }
  showScreen('scr-scan');
  document.getElementById('manual-id').value = '';

  var constraints = {
    video: {
      facingMode: { ideal: 'environment' },
      width:  { ideal: 1920 },
      height: { ideal: 1080 }
    }
  };

  navigator.mediaDevices.getUserMedia(constraints)
    .then(function(stream) {
      scanStream = stream;
      var v = document.getElementById('scan-video');
      v.srcObject = stream;
      v.play().then(function() {
        var c = document.getElementById('scan-canvas');
        c.width  = v.videoWidth  || 1280;
        c.height = v.videoHeight || 720;
        if (USE_NATIVE) {
          scanLoopNative(v);
        } else {
          scanLoopAPI(v, c, c.getContext('2d'));
        }
      });
    })
    .catch(function(err) {
      console.log('Camera error:', err.name, err.message);
      document.querySelector('.scan-hint').textContent = 'Камера недоступна — введите ID вручную ↓';
    });
}

// ── Вариант 1: BarcodeDetector (Chrome, Safari 17+) ──────────
function scanLoopNative(v) {
  if (!scanStream) return;
  detector.detect(v)
    .then(function(codes) {
      if (codes && codes.length > 0) {
        var text = codes[0].rawValue.trim();
        if (text) { stopScan(); lookupAndOpen(text); return; }
      }
      scanRAF = requestAnimationFrame(function() { scanLoopNative(v); });
    })
    .catch(function() {
      // Ошибка детектора — просто продолжаем
      scanRAF = requestAnimationFrame(function() { scanLoopNative(v); });
    });
}

// ── Вариант 2: api.qrserver.com (fallback) ───────────────────
// Делаем снимок каждые 800мс и отправляем на API
var apiScanTimer = null;

function scanLoopAPI(v, c, ctx) {
  if (!scanStream) return;
  apiScanTimer = setInterval(function() {
    if (!scanStream) { clearInterval(apiScanTimer); return; }
    if (v.readyState < v.HAVE_ENOUGH_DATA) return;

    ctx.drawImage(v, 0, 0, c.width, c.height);
    c.toBlob(function(blob) {
      if (!blob || !scanStream) return;
      var form = new FormData();
      form.append('file', blob, 'qr.jpg');
      fetch('https://api.qrserver.com/v1/read-qr-code/', {
        method: 'POST',
        body: form
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!scanStream) return;
        try {
          var text = data[0].symbol[0].data;
          if (text && text.trim()) {
            stopScan();
            lookupAndOpen(text.trim());
          }
        } catch(e) {
          // QR не найден на кадре — продолжаем
        }
      })
      .catch(function() {}); // сетевая ошибка — продолжаем
    }, 'image/jpeg', 0.9);
  }, 800);
}

function stopScan() {
  if (scanRAF)      { cancelAnimationFrame(scanRAF); scanRAF = null; }
  if (apiScanTimer) { clearInterval(apiScanTimer);   apiScanTimer = null; }
  if (scanStream)   { scanStream.getTracks().forEach(function(t){ t.stop(); }); scanStream = null; }
  showScreen('scr-main');
}

function manualLookup() {
  var id = document.getElementById('manual-id').value.trim().toUpperCase();
  if (!id) return;
  stopScan();
  lookupAndOpen(id);
}

// ── Поиск по ID ───────────────────────────────────
function lookupAndOpen(id) {
  var p = ALL.find(function(x){ return x.id.toUpperCase()===id.toUpperCase(); });
  if (p) { openDetail(p.id); return; }
  // Не нашли локально — спрашиваем сервер
  api({ action:'getPerson', id:id }).then(function(person){
    if (person.found) {
      cur = person;
      if (!ALL.find(function(x){ return x.id===person.id; })) ALL.push(person);
      showDetail(person);
    } else {
      document.getElementById('nf-id').textContent = id;
      document.getElementById('scr-nf').classList.add('on');
    }
  });
}

function openDetail(id) {
  var p = ALL.find(function(x){ return x.id===id; });
  if (p) { cur=p; showDetail(p); }
}

function showDetail(p) {
  var cs = CAT_CSS[p.category]||'blogger';
  var avCls = p.prefType==='лимит'&&p.remain<=0?'av-bad':'av-'+cs;
  document.getElementById('det-nm').textContent=p.name;
  var av=document.getElementById('d-av');
  av.textContent=ini(p.name); av.className='hero-ava '+avCls;
  document.getElementById('d-nm').textContent=p.name;
  var cat=document.getElementById('d-cat');
  cat.textContent=p.category; cat.className='hero-cat hc-'+cs;
  document.getElementById('amt').value='';
  document.getElementById('btn-rec').disabled=true;
  document.getElementById('owarn').classList.remove('on');
  document.getElementById('disc-calc').classList.remove('on');

  if (p.prefType==='лимит') {
    document.getElementById('block-limit').style.display='';
    document.getElementById('block-disc').style.display='none';
    var pct=Math.min(100,Math.max(0,p.spent/p.value*100));
    var st=p.remain<=0?'bad':p.remain<50?'warn':'ok';
    document.getElementById('d-lim').textContent=p.value+' р.';
    document.getElementById('d-sp').textContent=f(p.spent)+' р.';
    var rm=document.getElementById('d-rm'); rm.textContent=f(p.remain)+' р.'; rm.className='s3v c-'+st;
    var bar=document.getElementById('d-bar'); bar.style.width=pct.toFixed(0)+'%'; bar.className='prog-f f-'+st;
    document.getElementById('d-pct').textContent='Использовано '+pct.toFixed(0)+'%';
  } else {
    document.getElementById('block-limit').style.display='none';
    document.getElementById('block-disc').style.display='';
    var col=cs==='sport'?'var(--B)':'var(--O)';
    var pctEl=document.getElementById('d-pct-big');
    pctEl.textContent=p.value+'%'; pctEl.style.color=col;
    document.getElementById('dc-dlbl').textContent='Скидка '+p.value+'%';
    document.getElementById('d-disc-note').textContent=p.category+' · ID: '+p.id;
  }
  showScreen('scr-detail');
  document.getElementById('scr-detail').scrollTop=0;
  setTimeout(function(){ document.getElementById('amt').focus(); }, 150);
}

// ── Ввод суммы ────────────────────────────────────
document.getElementById('amt').addEventListener('input', function(){
  var a=parseFloat(this.value)||0;
  document.getElementById('btn-rec').disabled=!(a>0);
  if (!cur) return;
  if (cur.prefType==='скидка'&&a>0) {
    var disc=Math.round(a*(cur.value/100)*100)/100, pay=Math.round((a-disc)*100)/100;
    document.getElementById('dc-bill').textContent=f(a)+' р.';
    document.getElementById('dc-disc').textContent='−'+f(disc)+' р.';
    document.getElementById('dc-pay').textContent=f(pay)+' р.';
    document.getElementById('disc-calc').classList.add('on');
  } else { document.getElementById('disc-calc').classList.remove('on'); }
  if (cur.prefType==='лимит')
    document.getElementById('owarn').classList.toggle('on',a>cur.remain&&cur.remain>0);
});

// ── Запись ────────────────────────────────────────
document.getElementById('btn-rec').addEventListener('click', function(){
  var a=parseFloat(document.getElementById('amt').value);
  if (!cur||!a) return;
  var btn=this; btn.disabled=true; btn.textContent='Сохраняем...';

  api({ action:'addVisit', restaurant:presetRest||'', personId:cur.id, amount:a })
    .then(function(res){
      if (!res.success) throw new Error(res.error);
      if (cur.prefType==='лимит') {
        cur.spent=Math.round((cur.spent+a)*100)/100;
        cur.remain=Math.round((cur.value-cur.spent)*100)/100;
        var idx=ALL.findIndex(function(x){ return x.id===cur.id; });
        if (idx>=0) { ALL[idx].spent=cur.spent; ALL[idx].remain=cur.remain; }
      }
      showSuccess(presetRest||'', cur, a);
    })
    .catch(function(e){
      alert('Ошибка: '+e.message); btn.disabled=false; btn.textContent='Записать визит';
    });
});

function showSuccess(rest,p,a) {
  var cs=CAT_CSS[p.category]||'blogger';
  document.getElementById('ok-ring').className='ok-ring ok-ring-'+(cs==='blogger'?'g':cs==='sport'?'b':'o');
  document.getElementById('ok-check').setAttribute('stroke',cs==='blogger'?'#2E7D52':cs==='sport'?'#1a6fa8':'#b85c00');
  document.getElementById('ok-r').textContent=rest||'—';
  document.getElementById('ok-b').textContent=p.name;
  document.getElementById('ok-cat').textContent=p.category;
  document.getElementById('ok-a').textContent=f(a)+' р.';
  var discRow=document.getElementById('ok-disc-row'),payRow=document.getElementById('ok-pay-row'),remRow=document.getElementById('ok-rem-row');
  if (p.prefType==='скидка') {
    var disc=Math.round(a*(p.value/100)*100)/100,pay=Math.round((a-disc)*100)/100;
    document.getElementById('ok-dlbl').textContent='Скидка '+p.value+'%';
    document.getElementById('ok-disc').textContent='−'+f(disc)+' р.';
    document.getElementById('ok-pay').textContent=f(pay)+' р.';
    document.getElementById('ok-sub').textContent='Скидка применена';
    discRow.style.display='';payRow.style.display='';remRow.style.display='none';
  } else {
    var nr=cur.remain,rc=nr<=0?'var(--R)':nr<50?'var(--A)':'var(--G)';
    document.getElementById('ok-rem').textContent=f(nr)+' р.';
    document.getElementById('ok-rem').style.color=rc;
    document.getElementById('ok-sub').textContent='Лимит обновлён';
    discRow.style.display='none';payRow.style.display='none';remRow.style.display='';
  }
  showScreen('scr-ok');
}

// ── Навигация ─────────────────────────────────────
function closeDetail(){ showScreen('scr-main'); }
function home(){
  cur=null;
  document.getElementById('btn-rec').textContent='Записать визит';
  showScreen('scr-main');
  api({action:'getData'}).then(function(d){ ALL=d.people; draw(ALL); });
}
// ══ АВТОРИЗАЦИЯ ══
var AUTH_PASSWORD = 'salateira2025'; // ← замените на свой пароль
var AUTH_KEY = 'sal_auth_v1';

function checkAuth() {
  if (localStorage.getItem(AUTH_KEY) === AUTH_PASSWORD)
    document.getElementById('scr-auth').style.display = 'none';
}
function doAuth() {
  var val = document.getElementById('auth-inp').value;
  if (val === AUTH_PASSWORD) {
    localStorage.setItem(AUTH_KEY, val);
    document.getElementById('scr-auth').style.display = 'none';
  } else {
    document.getElementById('auth-err').classList.add('on');
    document.getElementById('auth-inp').value = '';
    document.getElementById('auth-inp').focus();
    var f = document.querySelector('.auth-field');
    [0,80,160,240].forEach(function(t,i){
      setTimeout(function(){
        f.style.transform=['translateX(8px)','translateX(-8px)','translateX(3px)','translateX(0)'][i];
      }, t);
    });
  }
}
function togglePwd() {
  var i = document.getElementById('auth-inp');
  var e = document.getElementById('auth-eye');
  i.type = i.type==='password' ? 'text' : 'password';
  e.textContent = i.type==='password' ? '👁' : '🙈';
}
checkAuth();
</script>
<div id="scr-auth">
  <div class="auth-logo">S</div>
  <div class="auth-title">Salateira</div>
  <div class="auth-sub">Введите пароль для входа</div>
  <div class="auth-field">
    <input type="password" id="auth-inp" placeholder="Пароль..."
           autocomplete="current-password" autocorrect="off"
           autocapitalize="off" spellcheck="false"
           onkeydown="if(event.key==='Enter')doAuth()"/>
    <button class="auth-eye" id="auth-eye" onclick="togglePwd()">👁</button>
  </div>
  <button class="auth-btn" onclick="doAuth()">Войти</button>
  <div class="auth-err" id="auth-err">Неверный пароль — попробуйте ещё раз</div>
</div>
</body>
</html>
