<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#1a5c38">
<title>Salateira</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --G:#38B04C;--GD:#1D712B;--GL:#e6f4ed;
  --B:#1a6fa8;--BL:#e8f2fb;
  --O:#b85c00;--OL:#fef3e2;
  --R:#d63031;--RL:#ffeaea;
  --A:#b7770d;--AL:#fff5dc;
  --BG:#f4f4f8;--WH:#fff;--T:#111;--M:#888;--BD:#e5e5e5;
  --pt:env(safe-area-inset-top,0px);
  --pb:env(safe-area-inset-bottom,0px);
}
html,body{width:100%;min-height:100dvh;overflow-x:hidden;
  background:var(--BG);font-family:-apple-system,BlinkMacSystemFont,'SF Pro Text','Segoe UI',sans-serif;
  color:var(--T);-webkit-font-smoothing:antialiased;
  -webkit-user-select:none;user-select:none;overscroll-behavior:none;}

/* ── Шапка ─────────────────────────────────── */
.appbar{background:var(--G);flex-shrink:0;padding:calc(16px + var(--pt)) 16px 0;}
.ab-row1{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.ab-logo{width:40px;height:40px;border-radius:12px;flex-shrink:0;background:rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;color:#fff;}
.ab-titles{flex:1;min-width:0;}
.ab-title{font-size:20px;font-weight:800;color:#fff;letter-spacing:-.3px;}
.ab-rest{display:inline-block;margin-top:3px;font-size:14px;font-weight:700;
  color:rgba(255,255,255,.9);background:rgba(255,255,255,.2);padding:3px 12px;border-radius:30px;}
.ab-search{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.16);
  border-radius:14px;padding:0 14px;height:48px;margin-bottom:14px;}
.ab-search input{flex:1;border:none;outline:none;background:none;font-size:17px;color:#fff;font-family:inherit;}
.ab-search input::placeholder{color:rgba(255,255,255,.5);}
.ab-clr{display:none;border:none;background:rgba(255,255,255,.25);color:#fff;
  width:24px;height:24px;border-radius:50%;font-size:14px;font-weight:700;cursor:pointer;
  align-items:center;justify-content:center;flex-shrink:0;}
.ab-clr.on{display:flex;}

/* ── Кнопка сканировать ─────────────────────── */
.scan-btn{display:flex;align-items:center;justify-content:center;gap:14px;
  background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.3);
  border-radius:18px;padding:18px 20px;margin:0 16px 14px;cursor:pointer;}
.scan-btn:active{background:rgba(255,255,255,.25);}
.scan-btn-icon{width:52px;height:52px;border-radius:14px;flex-shrink:0;
  background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;}
.scan-btn-txt h3{font-size:19px;font-weight:800;color:#fff;margin-bottom:3px;}
.scan-btn-txt p{font-size:14px;color:rgba(255,255,255,.75);}

/* ── Список ─────────────────────────────────── */
.screen{display:none;}
.screen.active{display:flex;flex-direction:column;min-height:100dvh;}
.sec-hdr{padding:14px 16px 6px;font-size:12px;font-weight:800;color:var(--M);text-transform:uppercase;letter-spacing:.6px;}
.list{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:0 12px calc(16px + var(--pb));}
.cat-hdr{display:flex;align-items:center;gap:10px;padding:16px 4px 8px;}
.cat-pill{padding:5px 14px;border-radius:30px;font-size:13px;font-weight:800;}
.cat-blogger{background:var(--GL);color:var(--G);}
.cat-sport  {background:var(--BL);color:var(--B);}
.cat-partner{background:var(--OL);color:var(--O);}
.cat-count{font-size:13px;color:var(--M);font-weight:600;}
.prow{background:var(--WH);border-radius:18px;padding:16px;margin-bottom:9px;
  display:flex;align-items:center;gap:14px;cursor:pointer;box-shadow:0 1px 4px rgba(0,0,0,.07);}
.prow:active{transform:scale(.98);}
.pava{width:52px;height:52px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;}
.av-blogger{background:var(--GL);color:var(--G);}
.av-sport  {background:var(--BL);color:var(--B);}
.av-partner{background:var(--OL);color:var(--O);}
.av-bad    {background:var(--RL);color:var(--R);}
.pinfo{flex:1;min-width:0;}
.pname{font-size:17px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px;}
.psub{font-size:13px;color:var(--M);}
.pbadge{flex-shrink:0;padding:8px 13px;border-radius:30px;font-size:14px;font-weight:800;white-space:nowrap;}
.pb-ok  {background:var(--GL);color:var(--G);}
.pb-warn{background:var(--AL);color:var(--A);}
.pb-bad {background:var(--RL);color:var(--R);}
.pb-b   {background:var(--BL);color:var(--B);}
.pb-o   {background:var(--OL);color:var(--O);}
.empty{text-align:center;padding:60px 20px;font-size:16px;color:var(--M);}
.skel-row{background:var(--WH);border-radius:18px;padding:16px;margin-bottom:9px;display:flex;align-items:center;gap:14px;}
.sk{background:#e8e8e8;border-radius:8px;animation:shimmer 1.2s infinite;}
.sk-c{width:52px;height:52px;border-radius:50%;flex-shrink:0;}
@keyframes shimmer{0%,100%{opacity:.5}50%{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── ЖИВОЙ СКАНЕР ───────────────────────────── */
#scr-scan{position:fixed;inset:0;background:#000;z-index:500;}
#scr-scan.active{display:flex;flex-direction:column;}
.scan-top{position:absolute;top:0;left:0;right:0;z-index:10;
  padding:calc(16px + var(--pt)) 16px 16px;
  display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(to bottom,rgba(0,0,0,.7),transparent);}
.scan-top-title{font-size:18px;font-weight:700;color:#fff;}
.scan-close{border:none;background:rgba(255,255,255,.2);color:#fff;
  width:44px;height:44px;border-radius:50%;font-size:24px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;}
#scan-video{width:100%;height:100%;object-fit:cover;}
#scan-canvas{display:none;}
/* Рамка с углами */
.scan-frame{position:absolute;top:50%;left:50%;transform:translate(-50%,-58%);
  width:250px;height:250px;border-radius:20px;}
.scan-overlay{position:absolute;inset:0;
  background:radial-gradient(ellipse 260px 260px at 50% 42%,transparent 49%,rgba(0,0,0,.55) 50%);}
.scan-border{position:absolute;top:50%;left:50%;transform:translate(-50%,-58%);
  width:250px;height:250px;border-radius:20px;border:3px solid rgba(255,255,255,.85);}
/* Угловые маркеры */
.scan-corners{position:absolute;inset:0;}
.sc::before,.sc::after{content:'';position:absolute;width:36px;height:36px;border:4px solid #fff;}
.sc-tl::before{top:-4px;left:-4px;border-right:none;border-bottom:none;border-radius:8px 0 0 0;}
.sc-tr::after {top:-4px;right:-4px;border-left:none;border-bottom:none;border-radius:0 8px 0 0;}
.sc-bl::before{bottom:-4px;left:-4px;border-right:none;border-top:none;border-radius:0 0 0 8px;}
.sc-br::after {bottom:-4px;right:-4px;border-left:none;border-top:none;border-radius:0 0 8px 0;}
/* Линия сканирования */
.scan-line{position:absolute;left:0;right:0;height:3px;
  background:linear-gradient(to right,transparent,var(--G),transparent);
  border-radius:2px;animation:scanline 2s linear infinite;}
@keyframes scanline{0%{top:0}100%{top:100%}}
/* Подсказка снизу */
.scan-hint{position:absolute;bottom:calc(18% + var(--pb));left:0;right:0;
  text-align:center;color:rgba(255,255,255,.8);font-size:15px;line-height:1.5;}
/* Ввод вручную */
.manual-bar{position:absolute;bottom:calc(50px + var(--pb));left:16px;right:16px;
  display:flex;gap:10px;}
.manual-bar input{flex:1;height:52px;border:none;outline:none;border-radius:14px;
  background:rgba(255,255,255,.15);color:#fff;font-size:17px;font-family:inherit;
  padding:0 16px;-webkit-user-select:text;user-select:text;backdrop-filter:blur(10px);}
.manual-bar input::placeholder{color:rgba(255,255,255,.55);}
.manual-bar button{height:52px;padding:0 20px;border:none;border-radius:14px;
  background:var(--G);color:#fff;font-size:16px;font-weight:700;font-family:inherit;cursor:pointer;white-space:nowrap;}

/* ── Детали ─────────────────────────────────── */
#scr-detail{position:fixed;inset:0;background:var(--BG);z-index:400;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.det-back{display:flex;align-items:center;gap:12px;padding:calc(14px + var(--pt)) 16px 14px;
  background:var(--WH);border-bottom:1px solid var(--BD);position:sticky;top:0;z-index:10;}
.back-btn{display:flex;align-items:center;gap:6px;border:none;background:var(--GL);color:var(--G);
  font-size:16px;font-weight:700;font-family:inherit;border-radius:12px;padding:9px 16px;cursor:pointer;flex-shrink:0;}
.det-nm{font-size:17px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.det-hero{margin:12px 12px 0;background:var(--WH);border-radius:22px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.07);}
.hero-top{display:flex;align-items:center;gap:16px;margin-bottom:18px;}
.hero-ava{width:68px;height:68px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:900;}
.hero-name{font-size:19px;font-weight:800;line-height:1.3;word-break:break-word;margin-bottom:6px;}
.hero-cat{display:inline-flex;align-items:center;padding:5px 13px;border-radius:30px;font-size:14px;font-weight:700;}
.hc-blogger{background:var(--GL);color:var(--G);}
.hc-sport  {background:var(--BL);color:var(--B);}
.hc-partner{background:var(--OL);color:var(--O);}
.stats3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:14px;}
.s3{background:var(--BG);border-radius:15px;padding:13px 10px;text-align:center;}
.s3l{font-size:11px;font-weight:800;color:var(--M);text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px;}
.s3v{font-size:22px;font-weight:900;}
.c-ok {color:var(--G);}
.c-warn{color:var(--A);}
.c-bad{color:var(--R);}
.prog{height:12px;background:#e5e5ea;border-radius:6px;overflow:hidden;}
.prog-f{height:100%;border-radius:6px;transition:width .4s ease;}
.f-ok{background:var(--G);}
.f-warn{background:#f0a500;}
.f-bad{background:var(--R);}
.prog-sub{font-size:13px;color:var(--M);margin-top:7px;text-align:right;}
.disc-block{text-align:center;padding:10px 0 4px;}
.disc-pct{font-size:64px;font-weight:900;line-height:1;margin-bottom:6px;}
.disc-lbl{font-size:16px;color:var(--M);margin-bottom:4px;}
.disc-note{font-size:14px;color:var(--M);}
.det-amt{margin:10px 12px 0;background:var(--WH);border-radius:22px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.07);}
.amt-lbl{font-size:13px;font-weight:800;color:var(--M);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px;}
.amt-field{display:flex;align-items:center;background:var(--BG);border-radius:16px;padding:0 18px;gap:8px;
  margin-bottom:10px;border:2.5px solid transparent;transition:border-color .15s,background .15s;}
.amt-field:focus-within{border-color:var(--G);background:var(--WH);}
.rub{font-size:30px;font-weight:900;color:#ccc;}
.amt-field input{flex:1;min-width:0;border:none;outline:none;background:none;
  font-size:36px;font-weight:900;color:var(--T);font-family:inherit;padding:14px 0;
  -webkit-user-select:text;user-select:text;}
.disc-calc{display:none;background:var(--BL);border-radius:14px;padding:14px 16px;margin-bottom:14px;}
.disc-calc.on{display:block;}
.dc-row{display:flex;justify-content:space-between;font-size:15px;padding:3px 0;}
.dc-key{color:var(--M);}
.dc-val{font-weight:700;}
.dc-total{display:flex;justify-content:space-between;font-size:18px;font-weight:900;
  padding-top:8px;margin-top:6px;border-top:1.5px solid rgba(26,111,168,.2);}
.over-warn{display:none;background:var(--AL);border-radius:13px;padding:12px 16px;
  font-size:14px;color:var(--A);margin-bottom:14px;line-height:1.4;}
.over-warn.on{display:block;}
.btn-rec{display:block;width:100%;padding:20px;background:var(--G);color:#fff;border:none;
  border-radius:18px;font-size:20px;font-weight:900;font-family:inherit;cursor:pointer;letter-spacing:-.4px;}
.btn-rec:disabled{background:#c8c8cc;}
.btn-rec:not(:disabled):active{background:var(--GD);transform:scale(.98);}
.det-space{height:calc(24px + var(--pb));}

/* ── Успех ──────────────────────────────────── */
#scr-ok{position:fixed;inset:0;background:var(--WH);z-index:600;display:none;
  flex-direction:column;align-items:center;justify-content:center;padding:32px 20px calc(32px + var(--pb));}
#scr-ok.active{display:flex;}
.ok-ring{width:100px;height:100px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:22px;}
.ok-ring-g{background:var(--GL);}
.ok-ring-b{background:var(--BL);}
.ok-ring-o{background:var(--OL);}
.ok-h{font-size:30px;font-weight:900;margin-bottom:6px;}
.ok-s{font-size:16px;color:var(--M);margin-bottom:28px;}
.receipt{width:100%;background:var(--BG);border-radius:20px;overflow:hidden;margin-bottom:22px;}
.rr{display:flex;justify-content:space-between;align-items:center;padding:16px 18px;
  border-bottom:1px solid #ebebeb;font-size:16px;gap:12px;}
.rr:last-child{border-bottom:none;}
.rk{color:var(--M);}
.rv{font-weight:800;text-align:right;max-width:58%;word-break:break-word;}
.rv.hl{font-size:20px;color:var(--G);}
.btn-again{width:100%;padding:20px;background:var(--G);color:#fff;border:none;
  border-radius:18px;font-size:19px;font-weight:900;font-family:inherit;cursor:pointer;}
.btn-again:active{background:var(--GD);}

/* ── Не найден ──────────────────────────────── */
.nf-wrap{position:fixed;inset:0;z-index:700;display:none;align-items:center;
  justify-content:center;background:rgba(0,0,0,.6);padding:24px;}
.nf-wrap.on{display:flex;}
.nf-card{background:var(--WH);border-radius:24px;padding:32px 24px;text-align:center;width:100%;max-width:340px;}
.nf-icon{font-size:48px;margin-bottom:14px;}
.nf-h{font-size:20px;font-weight:800;margin-bottom:8px;}
.nf-s{font-size:15px;color:var(--M);margin-bottom:16px;line-height:1.5;}
.nf-id{font-family:monospace;font-size:16px;background:var(--BG);padding:6px 14px;
  border-radius:8px;display:inline-block;margin-bottom:20px;}
.nf-btn{width:100%;padding:16px;border:none;border-radius:14px;background:var(--G);
  color:#fff;font-size:17px;font-weight:800;font-family:inherit;cursor:pointer;}

/* ── Медиа ──────────────────────────────────── */
@media(max-width:480px){
  .ab-title{font-size:22px;}
  .ab-search{height:52px;}
  .ab-search input{font-size:19px;}
  .scan-btn{padding:20px;margin:0 12px 14px;}
  .scan-btn-txt h3{font-size:21px;}
  .prow{padding:18px 14px;margin-bottom:10px;}
  .pava{width:58px;height:58px;font-size:20px;}
  .pname{font-size:18px;}
  .pbadge{font-size:15px;padding:9px 14px;}
  .hero-ava{width:74px;height:74px;font-size:26px;}
  .hero-name{font-size:21px;}
  .s3v{font-size:26px;}
  .disc-pct{font-size:72px;}
  .rub{font-size:34px;}
  .amt-field input{font-size:42px;padding:16px 0;}
  .btn-rec{padding:22px;font-size:22px;}
  .btn-again{padding:22px;font-size:21px;}
}
@media(min-width:600px){
  body{display:flex;justify-content:center;background:#ddd;}
  #scr-main{max-width:440px;width:100%;}
  #scr-detail,#scr-scan,#scr-ok{max-width:440px;left:50%;transform:translateX(-50%);}
  .nf-wrap{display:none;}
  .nf-wrap.on{display:flex;}
}
/* ══ АВТОРИЗАЦИЯ ══ */
#scr-auth{position:fixed;inset:0;z-index:1000;background:var(--G);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:32px 24px calc(32px + var(--pb));}
.auth-logo{width:80px;height:80px;border-radius:22px;background:rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:38px;font-weight:900;color:#fff;margin-bottom:24px;}
.auth-title{font-size:26px;font-weight:800;color:#fff;margin-bottom:8px;}
.auth-sub{font-size:16px;color:rgba(255,255,255,.7);margin-bottom:40px;text-align:center;}
.auth-field{width:100%;max-width:320px;background:rgba(255,255,255,.15);
  border:2px solid rgba(255,255,255,.25);border-radius:16px;padding:0 20px;
  height:58px;display:flex;align-items:center;margin-bottom:14px;
  transition:border-color .15s,background .15s;}
.auth-field:focus-within{background:rgba(255,255,255,.22);border-color:rgba(255,255,255,.6);}
.auth-field input{flex:1;border:none;outline:none;background:none;font-size:20px;
  font-weight:700;color:#fff;font-family:inherit;letter-spacing:3px;
  -webkit-user-select:text;user-select:text;}
.auth-field input::placeholder{color:rgba(255,255,255,.45);letter-spacing:0;font-weight:400;font-size:17px;}
.auth-eye{border:none;background:none;color:rgba(255,255,255,.6);
  font-size:20px;cursor:pointer;padding:4px;flex-shrink:0;}
.auth-btn{width:100%;max-width:320px;height:58px;background:#fff;color:var(--G);
  border:none;border-radius:16px;font-size:18px;font-weight:800;
  font-family:inherit;cursor:pointer;margin-bottom:14px;}
.auth-btn:active{opacity:.85;}
.auth-err{display:none;color:#ffcdd2;font-size:15px;text-align:center;}
.auth-err.on{display:block;}
</style>
</head>
<body>

<!-- ════ ГЛАВНЫЙ ЭКРАН ════════════════════════ -->
<div id="scr-main" class="screen active">
  <div class="appbar">
    <div class="ab-row1">
      <div class="ab-logo">S</div>
      <div class="ab-titles">
        <div class="ab-title">Salateira</div>
        <div id="ab-rest" class="ab-rest" style="display:none"></div>
      </div>
    </div>
    <div class="scan-btn" onclick="startScan()">
      <div class="scan-btn-icon">
        <svg width="28" height="28" fill="none" viewBox="0 0 28 28">
          <rect x="3" y="3" width="9" height="9" rx="2" stroke="white" stroke-width="2.5"/>
          <rect x="16" y="3" width="9" height="9" rx="2" stroke="white" stroke-width="2.5"/>
          <rect x="3" y="16" width="9" height="9" rx="2" stroke="white" stroke-width="2.5"/>
          <path d="M16 19h3M22 16v3M16 22h6" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="scan-btn-txt">
        <h3>Сканировать QR</h3>
        <p>Навести камеру на код гостя</p>
      </div>
      <svg width="20" height="20" fill="none" viewBox="0 0 20 20">
        <path d="M7 4l6 6-6 6" stroke="rgba(255,255,255,.6)" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="ab-search">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="7.5" stroke="rgba(255,255,255,.7)" stroke-width="2.5"/>
        <path d="M17 17l4 4" stroke="rgba(255,255,255,.7)" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <input id="q" type="text" placeholder="Поиск по имени или ID..."
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"/>
      <button class="ab-clr" id="qclr" onclick="clearQ()">✕</button>
    </div>
  </div>
  <div class="sec-hdr" id="sec-hdr">Загрузка...</div>
  <div class="list" id="list">
    <div class="skel-row"><div class="sk sk-c"></div><div style="flex:1"><div class="sk" style="height:16px;width:60%;margin-bottom:8px"></div><div class="sk" style="height:12px;width:40%"></div></div></div>
    <div class="skel-row"><div class="sk sk-c"></div><div style="flex:1"><div class="sk" style="height:16px;width:70%;margin-bottom:8px"></div><div class="sk" style="height:12px;width:45%"></div></div></div>
    <div class="skel-row"><div class="sk sk-c"></div><div style="flex:1"><div class="sk" style="height:16px;width:55%;margin-bottom:8px"></div><div class="sk" style="height:12px;width:35%"></div></div></div>
  </div>
</div>

